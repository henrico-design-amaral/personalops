---
// PersonalOps Operating Shell - Orchestrator
// Offline-first shell with role-based views and access control
// This is a demo/prototype page - shows different views based on selected role

import BaseLayout from '../layouts/BaseLayout.astro';
import { renderRoleSwitcher } from '../lib/shell/render-shared.js';
---

<BaseLayout title="PersonalOps - Operating Shell">
  <div id="screen-app" class="screen active">
    <!-- Topbar -->
    <header class="topbar">
      <button id="btn-menu" class="topbar-menu" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <div class="topbar-brand">
        <span class="brand-icon-sm">⚡</span>
        <span class="topbar-title" id="page-title">PersonalOps Shell</span>
      </div>
      <div class="topbar-right">
        <span id="status-indicator" class="status-dot online" title="Online"></span>
        <button id="btn-logout" class="topbar-logout" aria-label="Sair" onclick="window.location.hash='#/entrar'; window.location.reload();">⎋</button>
      </div>
    </header>

    <!-- Sidebar -->
    <nav id="sidebar" class="sidebar">
      <div class="sidebar-profile" id="user-status-card">
        <!-- Loaded dynamically -->
      </div>
      
      <!-- Role Switcher for demo -->
      <div class="role-switcher-container" style="padding: 16px; border-bottom: 1px solid var(--border);">
        {renderRoleSwitcher && <Fragment set:html={renderRoleSwitcher()} />}
      </div>

      <ul class="nav-list" id="sidebar-menu">
        <!-- Dynamic links loaded via script -->
      </ul>
      
      <div class="sidebar-footer">
        <span class="version-label">PersonalOps v1.4 — Shell</span>
      </div>
    </nav>
    <div id="sidebar-overlay" class="sidebar-overlay hidden"></div>

    <!-- Main Content -->
    <main class="main-content" id="main-content">
      <div id="views-container" class="views-container">
        <div id="loading" class="loading">
          <p>Loading fixtures and access control...</p>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<style is:global>
  /* Operating Shell View Styles - Globalized to apply to dynamic client-side HTML */
  .views-container {
    min-height: 400px;
  }

  .loading {
    text-align: center;
    color: var(--text-secondary);
    padding: 60px 40px;
  }

  .view {
    display: none;
    animation: fadeIn 0.2s ease-out;
  }

  .view.active {
    display: block;
  }

  /* View Header Component */
  .view-header {
    background: var(--bg-surface);
    border-left: 4px solid var(--accent);
    padding: 16px 20px;
    margin-bottom: 24px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    border-left-width: 4px;
  }

  .view-header h2 {
    color: var(--text-primary);
    margin: 0 0 4px 0;
    font-size: 20px;
    font-weight: 700;
  }

  .view-header .info {
    color: var(--text-secondary);
    font-size: 12px;
    margin: 0;
  }

  /* Section Titles */
  h3[style*="color: #64c8ff"], h3[style*="color: var(--accent-blue)"] {
    color: var(--accent) !important;
    font-size: 15px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
    margin-top: 24px !important;
    margin-bottom: 14px !important;
  }

  /* Grid Layouts for Cards */
  .admin-professors, .professor-students {
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)) !important;
    gap: 16px !important;
  }

  /* Premium Cards */
  .professor-card, .student-card, .portal-section {
    background: var(--bg-surface) !important;
    border: 1px solid var(--border) !important;
    border-radius: var(--radius) !important;
    padding: 16px !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15) !important;
    transition: all 0.2s ease !important;
    box-sizing: border-box !important;
  }

  .professor-card:hover, .student-card:hover {
    border-color: var(--border-active) !important;
    transform: translateY(-2px);
  }

  .professor-header {
    color: var(--accent) !important;
    font-weight: 700 !important;
    margin-bottom: 8px !important;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px !important;
  }

  .student-list {
    margin-top: 12px !important;
    padding-top: 8px !important;
    border-top: 1px solid var(--border) !important;
  }

  .student-item {
    color: var(--text-primary) !important;
    padding: 6px 0 !important;
    font-size: 12px !important;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Badges & Status Pills */
  .student-status {
    display: inline-block !important;
    padding: 3px 8px !important;
    border-radius: 100px !important;
    font-size: 9px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
  }

  .status-ativo {
    background: var(--success-dim) !important;
    border: 1px solid rgba(34, 197, 94, 0.3) !important;
    color: var(--success) !important;
  }

  .status-pausado {
    background: var(--warn-dim) !important;
    border: 1px solid rgba(245, 158, 11, 0.3) !important;
    color: var(--warn) !important;
  }

  .status-arquivado {
    background: rgba(255, 255, 255, 0.05) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    color: var(--text-secondary) !important;
  }

  .student-status.expired {
    background: var(--danger-dim) !important;
    border: 1px solid rgba(239, 68, 68, 0.3) !important;
    color: var(--danger) !important;
  }

  .student-name {
    color: var(--accent) !important;
    font-weight: 700 !important;
    margin-bottom: 6px !important;
    font-size: 14px !important;
  }

  .student-details {
    color: var(--text-secondary) !important;
    font-size: 12px !important;
    margin-bottom: 12px !important;
    line-height: 1.5 !important;
  }

  /* Form Control Styling */
  input[type="text"], input[type="number"], select, textarea {
    background: var(--bg-elevated) !important;
    border: 1px solid var(--border) !important;
    color: var(--text-primary) !important;
    border-radius: var(--radius-sm) !important;
    padding: 8px 12px !important;
    font-size: 13px !important;
    font-family: inherit !important;
    transition: all 0.2s !important;
    outline: none !important;
    box-sizing: border-box !important;
  }

  input[type="text"]:focus, input[type="number"]:focus, select:focus, textarea:focus {
    border-color: var(--accent) !important;
    box-shadow: 0 0 0 2px var(--accent-dim) !important;
  }

  /* Buttons Design */
  .button {
    display: inline-block !important;
    padding: 6px 12px !important;
    background: var(--accent-dim) !important;
    border: 1px solid rgba(99, 102, 241, 0.3) !important;
    color: var(--accent) !important;
    border-radius: var(--radius-sm) !important;
    cursor: pointer !important;
    font-size: 12px !important;
    font-weight: 600 !important;
    margin-right: 6px !important;
    margin-bottom: 6px !important;
    transition: all 0.2s ease !important;
    outline: none !important;
    text-align: center !important;
  }

  .button:hover {
    background: rgba(99, 102, 241, 0.25) !important;
    border-color: var(--border-active) !important;
    transform: translateY(-1px) !important;
  }

  .button:active {
    transform: translateY(0) !important;
  }

  /* Primary action styles (green buttons) */
  button.button[style*="#64c864"], 
  button.button[style*="100, 200, 100"], 
  .button-primary {
    background: var(--success-dim) !important;
    border-color: rgba(34, 197, 94, 0.3) !important;
    color: var(--success) !important;
  }

  button.button[style*="#64c864"]:hover, 
  button.button[style*="100, 200, 100"]:hover {
    background: rgba(34, 197, 94, 0.25) !important;
    border-color: var(--success) !important;
  }

  /* Danger action styles (red buttons) */
  button.button[style*="#ff6464"], 
  button.button[style*="200, 100, 100"],
  .button-danger {
    background: var(--danger-dim) !important;
    border-color: rgba(239, 68, 68, 0.3) !important;
    color: var(--danger) !important;
  }

  button.button[style*="#ff6464"]:hover, 
  button.button[style*="200, 100, 100"]:hover {
    background: rgba(239, 68, 68, 0.25) !important;
    border-color: var(--danger) !important;
  }

  /* Placeholder box */
  .placeholder {
    color: var(--text-secondary) !important;
    font-size: 12px !important;
    padding: 24px !important;
    text-align: center !important;
    background: rgba(0, 0, 0, 0.15) !important;
    border-radius: var(--radius-sm) !important;
    border: 1px dashed var(--border) !important;
  }

  /* Access Denied View */
  .access-denied {
    background: var(--danger-dim) !important;
    border: 1px solid rgba(239, 68, 68, 0.3) !important;
    border-radius: var(--radius) !important;
    padding: 40px !important;
    text-align: center !important;
  }

  .access-denied h2 {
    color: var(--danger) !important;
    margin: 0 0 8px 0 !important;
  }

  .access-denied p {
    color: var(--text-secondary) !important;
    margin: 0 !important;
  }

  /* Modals Override styling */
  div[style*="position: fixed"] {
    background: rgba(5, 5, 8, 0.85) !important;
    backdrop-filter: blur(8px) !important;
    animation: fadeIn 0.2s ease-out !important;
  }

  div[style*="position: fixed"] > div {
    background: var(--bg-surface) !important;
    border: 1px solid var(--border) !important;
    border-radius: var(--radius-lg) !important;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5) !important;
    padding: 24px !important;
    animation: slideUp 0.25s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }

  /* Weekly plan editor grids */
  div[style*="display: flex; gap: 8px; flex-wrap: wrap"] {
    display: grid !important;
    grid-template-columns: repeat(7, 1fr) !important;
    gap: 10px !important;
  }

  /* Hide redundant selector header/disclaimer inside sidebar container */
  .role-switcher h1, .role-switcher .disclaimer {
    display: none !important;
  }
  .role-switcher {
    background: transparent !important;
    border: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }
  .role-switcher-container label {
    font-size: 11px;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: block;
    margin-bottom: 6px;
  }
  .role-switcher-container select {
    width: 100%;
  }

  /* Animations */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from { transform: translateY(12px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  /* Mobile responsive overrides */
  @media (max-width: 768px) {
    .topbar-menu {
      display: flex !important;
    }
    .sidebar {
      transform: translateX(-100%);
      transition: transform var(--transition);
      z-index: 1000;
    }
    .sidebar.open {
      transform: translateX(0);
    }
    .sidebar-overlay {
      display: block;
    }
    div[style*="display: flex; gap: 8px; flex-wrap: wrap"],
    div[style*="display: grid; grid-template-columns: repeat(7, 1fr)"] {
      grid-template-columns: 1fr !important;
      gap: 8px !important;
    }
  }
</style>

<script>
  import { createShellState } from '../lib/shell-state.js';
  import { renderAccessDenied } from '../lib/shell/render-shared.js';
  import { renderAdminView } from '../lib/shell/render-admin.js';
  import { renderProfessorView } from '../lib/shell/render-professor.js';
  import { renderStudentView } from '../lib/shell/render-student.js';
  import { getActorContext } from '../lib/access-control.js';
  import { loadFixtures } from '../lib/fixtures-loader.js';
  import { renderWorkoutBuilderModal } from '../lib/shell/schedule-utils.js';

  const state = createShellState();
  let fixtures = null;

  async function initShell() {
    try {
      fixtures = await loadFixtures();
      
      const select = document.getElementById('role-select');
      if (select) {
        select.value = state.currentUserId;
        select.addEventListener('change', (e) => {
          state.setCurrentUser(e.target.value);
          renderView();
        });
      }
      
      // Bind mobile menu interactions
      const btnMenu = document.getElementById('btn-menu');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      
      if (btnMenu && sidebar && overlay) {
        btnMenu.addEventListener('click', () => {
          sidebar.classList.toggle('open');
          overlay.classList.toggle('hidden');
        });
        overlay.addEventListener('click', () => {
          sidebar.classList.remove('open');
          overlay.classList.add('hidden');
        });
      }
      
      renderView();
    } catch (error) {
      console.error('Failed to load fixtures:', error);
      document.getElementById('loading').innerHTML = '<p style="color: var(--danger);">Error loading fixtures</p>';
    }
  }

  function renderView() {
    const actor = getActorContext(state.currentUserId, fixtures);

    if (!actor) {
      document.getElementById('views-container').innerHTML = renderAccessDenied('User not found');
      return;
    }

    let html = '';
    if (actor.roles.includes('admin')) {
      html = renderAdminView(actor, fixtures);
    } else if (actor.roles.includes('professor')) {
      html = renderProfessorView(actor, fixtures, state);
    } else if (actor.roles.includes('student')) {
      html = renderStudentView(actor, fixtures, state);
    } else {
      html = renderAccessDenied('Unknown role');
    }

    if (state.creatingWorkout && actor.roles.includes('professor')) {
      html += renderWorkoutBuilderModal(state, fixtures, actor);
    }

    document.getElementById('views-container').innerHTML = html;

    // Dynamically update sidebar navigation links and active status card
    updateSidebar(actor);
    
    // Close sidebar on mobile after render/navigation
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    if (sidebar && overlay) {
      sidebar.classList.remove('open');
      overlay.classList.add('hidden');
    }
  }

  function updateSidebar(actor) {
    const menu = document.getElementById('sidebar-menu');
    const pageTitle = document.getElementById('page-title');
    const userStatusCard = document.getElementById('user-status-card');
    
    if (!menu || !actor) return;
    
    let menuHtml = '';
    let statusHtml = '';
    
    if (actor.roles.includes('admin')) {
      if (pageTitle) pageTitle.innerText = 'Platform Administrator';
      menuHtml = `
        <li class="nav-item active" onclick="this.parentElement.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active')); this.classList.add('active');"><span class="nav-icon">📊</span>Platform Dashboard</li>
        <li class="nav-item" onclick="this.parentElement.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active')); this.classList.add('active'); setTimeout(() => document.querySelector('[style*=\\'Exercise Library\\']')?.scrollIntoView({behavior:\'smooth\'}), 100)"><span class="nav-icon">🏋️</span>Exercise Library</li>
        <li class="nav-item" onclick="this.parentElement.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active')); this.classList.add('active'); setTimeout(() => document.querySelector('[style*=\\'Recent Support\\']')?.scrollIntoView({behavior:\'smooth\'}), 100)"><span class="nav-icon">🛡️</span>Support Action Logs</li>
      `;
      statusHtml = `
        <div class="avatar">AD</div>
        <div>
          <div class="profile-name">Admin Control</div>
          <div class="profile-role">Administrator</div>
        </div>
      `;
    } else if (actor.roles.includes('professor')) {
      if (pageTitle) pageTitle.innerText = `Trainer Portal — ${actor.professorProfile.name}`;
      
      const isViewingStudent = !!state.selectedStudentId;
      if (isViewingStudent) {
        const student = fixtures.studentProfiles.find(s => s.id === state.selectedStudentId);
        menuHtml = `
          <li class="nav-item" onclick="window.selectStudent(null); return false;"><span class="nav-icon">←</span>Back to Dashboard</li>
          <li class="nav-item active"><span class="nav-icon">📋</span>Student Profile: ${student?.name}</li>
        `;
      } else {
        menuHtml = `
          <li class="nav-item active" onclick="this.parentElement.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active')); this.classList.add('active');"><span class="nav-icon">👥</span>My Students</li>
          <li class="nav-item" onclick="this.parentElement.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active')); this.classList.add('active'); setTimeout(() => document.querySelector('[style*=\\'Create Workout\\']')?.scrollIntoView({behavior:\'smooth\'}), 100)"><span class="nav-icon">💪</span>Workout Builder</li>
          <li class="nav-item" onclick="this.parentElement.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active')); this.classList.add('active'); setTimeout(() => document.querySelector('[style*=\\'Cashflow Control\\']')?.scrollIntoView({behavior:\'smooth\'}), 100)"><span class="nav-icon">💰</span>Cashflow Control</li>
        `;
      }
      statusHtml = `
        <div class="avatar">TR</div>
        <div>
          <div class="profile-name">${actor.professorProfile.name}</div>
          <div class="profile-role">${actor.professorProfile.specialty}</div>
        </div>
      `;
    } else if (actor.roles.includes('student')) {
      if (pageTitle) pageTitle.innerText = `Student Portal — ${actor.studentProfile.name}`;
      menuHtml = `
        <li class="nav-item active" onclick="this.parentElement.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active')); this.classList.add('active');"><span class="nav-icon">📅</span>Training Schedule</li>
        <li class="nav-item" onclick="this.parentElement.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active')); this.classList.add('active'); setTimeout(() => document.querySelector('[style*=\\'My Workouts\\']')?.scrollIntoView({behavior:\'smooth\'}), 100)"><span class="nav-icon">🏋️</span>My Workouts</li>
        <li class="nav-item" onclick="this.parentElement.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active')); this.classList.add('active'); setTimeout(() => document.querySelector('[style*=\\'Profile\\']')?.scrollIntoView({behavior:\'smooth\'}), 100)"><span class="nav-icon">⚙️</span>Profile Settings</li>
      `;
      statusHtml = `
        <div class="avatar">ST</div>
        <div>
          <div class="profile-name">${actor.studentProfile.name}</div>
          <div class="profile-role">Student</div>
        </div>
      `;
    }
    
    menu.innerHTML = menuHtml;
    if (userStatusCard) userStatusCard.innerHTML = statusHtml;
  }

  window.selectStudent = function(studentId) {
    state.selectStudent(studentId);
    renderView();
  };

  window.openWeeklyPlanEditor = function(studentId, weekday) {
    state.openWeeklyPlanEditor(studentId, weekday);
    renderView();
  };

  window.closeWeeklyPlanEditor = function() {
    state.closeWeeklyPlanEditor();
    renderView();
  };

  window.openWorkoutBuilder = function() {
    state.openWorkoutBuilder();
    renderView();
  };

  window.closeWorkoutBuilder = function() {
    state.closeWorkoutBuilder();
    renderView();
  };

  window.updateWorkoutBuilder = function(updates) {
    state.updateWorkoutBuilder(updates);
  };

  window.addSelectedExercise = function() {
    const select = document.getElementById('exercise-select');
    if (!select || !select.value) return;

    const [id, name, category, equipment, difficulty] = select.value.split('|');
    state.addExerciseToWorkout({ exerciseId: id, exerciseName: name, category, equipment, difficulty });
    select.value = '';
    renderView();
  };

  window.removeExerciseFromWorkout = function(index) {
    state.removeExerciseFromWorkout(index);
    renderView();
  };

  window.openWorkoutDetail = function(workoutId) {
    state.openWorkoutDetail(workoutId);
    renderView();
  };

  window.closeWorkoutDetail = function() {
    state.closeWorkoutDetail();
    renderView();
  };

  window.addEventListener('DOMContentLoaded', initShell);
</script>
