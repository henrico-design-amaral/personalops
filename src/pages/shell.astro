---
// PersonalOps Operating Shell - Orchestrator
// Offline-first shell with role-based views and access control
// This is a demo/prototype page - shows different views based on selected role

import BaseLayout from '../layouts/BaseLayout.astro';
import { renderRoleSwitcher } from '../lib/shell/render-shared.js';
---

<BaseLayout title="PersonalOps - Operating Shell">
  <div class="shell-container">
    {renderRoleSwitcher && renderRoleSwitcher()}
    <div id="views-container" class="views-container">
      <div id="loading" class="loading">
        <p>Loading fixtures and access control...</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .shell-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
  }

  .role-switcher {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(100, 200, 255, 0.2);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 30px;
  }

  .role-switcher h1 {
    color: #64c8ff;
    margin: 0 0 20px 0;
    font-size: 24px;
  }

  .switcher-controls {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 15px;
  }

  .switcher-controls label {
    color: #a0a0a0;
    font-size: 14px;
  }

  .switcher-controls select {
    padding: 8px 12px;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(100, 200, 255, 0.3);
    color: #64c8ff;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
  }

  .switcher-controls select:hover {
    background: rgba(0, 0, 0, 0.7);
    border-color: rgba(100, 200, 255, 0.6);
  }

  .disclaimer {
    color: #a0a0a0;
    font-size: 12px;
    margin: 0;
    line-height: 1.5;
  }

  .views-container {
    min-height: 400px;
  }

  .loading {
    text-align: center;
    color: #a0a0a0;
    padding: 40px;
  }

  .view {
    display: none;
  }

  .view.active {
    display: block;
  }

  .view-header {
    background: rgba(0, 0, 0, 0.3);
    border-left: 4px solid #64c8ff;
    padding: 15px;
    margin-bottom: 20px;
    border-radius: 4px;
  }

  .view-header h2 {
    color: #64c8ff;
    margin: 0 0 5px 0;
    font-size: 20px;
  }

  .view-header .info {
    color: #a0a0a0;
    font-size: 12px;
    margin: 0;
  }

  .admin-professors {
    display: grid;
    gap: 20px;
  }

  .professor-card {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(100, 200, 255, 0.2);
    border-radius: 8px;
    padding: 15px;
  }

  .professor-header {
    color: #64c8ff;
    font-weight: bold;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .student-list {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid rgba(100, 200, 255, 0.1);
  }

  .student-item {
    color: #d0d0d0;
    padding: 8px 0;
    font-size: 13px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .student-status {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: bold;
  }

  .status-ativo {
    background: rgba(100, 200, 100, 0.3);
    color: #64c864;
  }

  .status-pausado {
    background: rgba(255, 200, 100, 0.3);
    color: #ffc864;
  }

  .status-arquivado {
    background: rgba(150, 150, 150, 0.3);
    color: #a0a0a0;
  }

  .professor-students {
    display: grid;
    gap: 15px;
  }

  .student-card {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(100, 200, 255, 0.2);
    border-radius: 8px;
    padding: 15px;
  }

  .student-name {
    color: #64c8ff;
    font-weight: bold;
    margin-bottom: 8px;
  }

  .student-details {
    color: #a0a0a0;
    font-size: 12px;
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .button {
    display: inline-block;
    padding: 6px 12px;
    background: rgba(100, 200, 255, 0.2);
    border: 1px solid rgba(100, 200, 255, 0.4);
    color: #64c8ff;
    border-radius: 4px;
    cursor: pointer;
    font-size: 12px;
    margin-right: 8px;
    transition: all 0.2s;
  }

  .button:hover {
    background: rgba(100, 200, 255, 0.3);
    border-color: rgba(100, 200, 255, 0.6);
  }

  .student-portal {
    display: grid;
    gap: 20px;
  }

  .portal-section {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(100, 200, 255, 0.2);
    border-radius: 8px;
    padding: 15px;
  }

  .portal-section h3 {
    color: #64c8ff;
    margin: 0 0 10px 0;
    font-size: 14px;
  }

  .placeholder {
    color: #a0a0a0;
    font-size: 12px;
    padding: 20px;
    text-align: center;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 4px;
    border: 1px dashed rgba(100, 200, 255, 0.2);
  }

  .access-denied {
    background: rgba(200, 100, 100, 0.2);
    border: 2px solid rgba(200, 100, 100, 0.5);
    border-radius: 8px;
    padding: 40px;
    text-align: center;
  }

  .access-denied h2 {
    color: #ff6464;
    margin: 0 0 10px 0;
  }

  .access-denied p {
    color: #a0a0a0;
    margin: 0;
  }
</style>

<script>
  import { createShellState } from '../lib/shell-state.js';
  import { renderAccessDenied } from '../lib/shell/render-shared.js';
  import { renderAdminView } from '../lib/shell/render-admin.js';
  import { renderProfessorView } from '../lib/shell/render-professor.js';
  import { renderStudentView } from '../lib/shell/render-student.js';
  import { getActorContext } from '../lib/access-control.js';
  import { loadFixtures } from '../lib/fixtures-loader.js';
  import { renderWorkoutBuilderModal } from '../lib/shell/schedule-utils.js';

  const state = createShellState();
  let fixtures = null;

  async function initShell() {
    try {
      fixtures = await loadFixtures();
      renderView();
    } catch (error) {
      console.error('Failed to load fixtures:', error);
      document.getElementById('loading').innerHTML = '<p style="color: #ff6464;">Error loading fixtures</p>';
    }
  }

  function renderView() {
    const actor = getActorContext(state.currentUserId, fixtures);

    if (!actor) {
      document.getElementById('views-container').innerHTML = renderAccessDenied('User not found');
      return;
    }

    let html = '';
    if (actor.roles.includes('admin')) {
      html = renderAdminView(actor, fixtures);
    } else if (actor.roles.includes('professor')) {
      html = renderProfessorView(actor, fixtures, state);
    } else if (actor.roles.includes('student')) {
      html = renderStudentView(actor, fixtures, state);
    } else {
      html = renderAccessDenied('Unknown role');
    }

    if (state.creatingWorkout && actor.roles.includes('professor')) {
      html += renderWorkoutBuilderModal(state, fixtures, actor);
    }

    document.getElementById('views-container').innerHTML = html;
  }

  window.selectStudent = function(studentId) {
    state.selectStudent(studentId);
    renderView();
  };

  window.openWeeklyPlanEditor = function(studentId, weekday) {
    state.openWeeklyPlanEditor(studentId, weekday);
    renderView();
  };

  window.closeWeeklyPlanEditor = function() {
    state.closeWeeklyPlanEditor();
    renderView();
  };

  window.openWorkoutBuilder = function() {
    state.openWorkoutBuilder();
    renderView();
  };

  window.closeWorkoutBuilder = function() {
    state.closeWorkoutBuilder();
    renderView();
  };

  window.updateWorkoutBuilder = function(updates) {
    state.updateWorkoutBuilder(updates);
  };

  window.addSelectedExercise = function() {
    const select = document.getElementById('exercise-select');
    if (!select || !select.value) return;

    const [id, name, category, equipment, difficulty] = select.value.split('|');
    state.addExerciseToWorkout({ exerciseId: id, exerciseName: name, category, equipment, difficulty });
    select.value = '';
    renderView();
  };

  window.removeExerciseFromWorkout = function(index) {
    state.removeExerciseFromWorkout(index);
    renderView();
  };

  window.openWorkoutDetail = function(workoutId) {
    state.openWorkoutDetail(workoutId);
    renderView();
  };

  window.closeWorkoutDetail = function() {
    state.closeWorkoutDetail();
    renderView();
  };

  document.getElementById('role-select').addEventListener('change', (e) => {
    state.setCurrentUser(e.target.value);
    renderView();
  });

  window.addEventListener('DOMContentLoaded', initShell);
</script>
