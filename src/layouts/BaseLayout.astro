---
import { getCollection } from 'astro:content';

// PersonalOps Base Layout
// Maintains parity with original index.html structure
// Uses Astro.url to generate correct asset paths for GitHub Pages deployment

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'PersonalOps',
  description = 'Operational prototype for personal trainer workflows'
} = Astro.props;

// Get base URL for correct asset paths on GitHub Pages
const baseUrl = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0f" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- PWA & Manifest -->
    <link rel="manifest" href={baseUrl + 'manifest.webmanifest'} />

    <!-- Stylesheet -->
    <link rel="stylesheet" href={baseUrl + 'assets/css/app.css'} />

    <!-- Service Worker Registration -->
    <script is:inline define:vars={{ baseUrl }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(baseUrl + 'service-worker.js');
        });
      }
    </script>
  </head>
  <body>
    <!-- Page content slot (for shell.astro and others) or app shell (for index.astro) -->
    <slot>
      <!-- Default: App Shell for index.astro -->
      <div id="app" class="app-shell"></div>

      <!-- Data Store (global) -->
      <script src={baseUrl + 'assets/js/data-store.js'} defer></script>

      <!-- App Main (client-side island) -->
      <script src={baseUrl + 'assets/js/app.js'} defer></script>
    </slot>
  </body>
</html>

<style is:global>
  /* Layout wrapper ensures consistent structure */
  html, body {
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
  }
</style>
